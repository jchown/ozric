    private void DoDelete()
    {
        var selectedItems = Diagram.GetSelectedModels().ToList();
        if (selectedItems.Count > 0)
        {
            var actions = GraphEditAction.Build(GetDeleteActions(selectedItems));
            GraphEditState.DoAction(actions);

            OnHistoryChanged();
        }
    }

    private IEnumerable<GraphEditAction> GetDeleteActions(List<SelectableModel> selectableModels)
    {
        HashSet<SelectableModel> deleting = new(); 
            
        foreach (var selected in selectableModels)
        {
            foreach (var action in GetDeleteActions(deleting, selected))
            {
                yield return action;
            }
        }
    }

    private IEnumerable<GraphEditAction> GetDeleteActions(HashSet<SelectableModel> deleting, SelectableModel selectableModel)
    {
        if (!deleting.Add(selectableModel))
            yield break;
        
        switch (selectableModel)
        {
            case DiagramNode gnm:
            {
                foreach (var link in gnm.Ports.SelectMany(p => p.Links))
                {
                    foreach (var deleteAction in GetDeleteActions(deleting, link))
                        yield return deleteAction;
                }

                yield return new GraphEditAction.RemoveNode(nodeMappings.GetGraph(gnm));
                break;
            }

            case LinkModel lm:
            {
                foreach (var deleteAction in GetDeleteActions(lm))
                    yield return deleteAction;
                    
                break;
            }

            default:
                throw new ArgumentOutOfRangeException();
        }
    }

    private IEnumerable<GraphEditAction> GetDeleteActions(LinkModel lm)
    {
        var edge = edgeMappings.GetGraph(lm);
        if (lm.Target.Model is DiagramVariableInputs vim)
        {
            var inputNode = (GraphVariableInputs)vim.graphNode;
            yield return new GraphEditAction.RemoveInput(inputNode, edge.to.inputName);
            yield return new GraphEditAction.RemoveEdge(edge);
            yield break;
        }

        yield return new GraphEditAction.RemoveEdge(edge);
    }

    public void AddNodeInput(GraphVariableInputs variableInputs, string inputName)
    {
        var input = variableInputs.AddInput(inputName);
        var model = (DiagramVariableInputs) nodeMappings.GetDiagram(variableInputs);
        model.AddVariableInput(input);
    }

    public void RemoveNodeInput(GraphVariableInputs variableInputs, string inputName)
    {
        var input = variableInputs.RemoveInput(inputName);
        var model = (DiagramVariableInputs) nodeMappings.GetDiagram(variableInputs);
        model.RemoveInput(input);
    }


    public DiagramNode GetDiagramNode(string nodeID)
    {
        return nodeMappings.GetDiagram(Graph.nodes[nodeID]);
    }

    private record UnassignedEntity(string Name, string Icon, Func<GraphNode> Create);

    private bool _unassignedExpanded;
    private List<UnassignedEntity> _unassignedEntities = new();

    private void ToggleUnassigned()
    {
        _unassignedExpanded = !_unassignedExpanded;
    }

    private void UpdateUnassignedEntities()
    {
        if (OzricService?.Home == null || Graph == null || string.IsNullOrEmpty(AreaId))
        {
            _unassignedEntities = new();
            return;
        }

        var home = OzricService.Home;
        var entitiesInArea = home.GetEntitiesInArea(AreaId);
        var entityStates = home.GetEntityStates();
        var usableDevices = entityStates.Where(d => CategoryModelMappings.Exists(d.GetCategory())).ToList();
        var unusedDevices = usableDevices.Where(d => !Graph.HasEntityNode(d.entity_id)).ToList();
        var unusedInArea = unusedDevices
            .Where(d => entitiesInArea.Any(e => e.entity_id == d.entity_id))
            .ToList();

        _unassignedEntities = unusedInArea.Select(d =>
        {
            var entityID = d.entity_id;
            var category = d.GetCategory();
            var type = CategoryModelMappings.Get(category);
            var icon = AddNodeChoice.GetEntityIcon(type) ?? "icon-park-outline:chip";
            var id = entityID.Substring(entityID.IndexOf('.') + 1);
            if (Graph.HasEntityNode(id))
                id = Graph.CreateNodeID(category.ToString().ToLowerInvariant());
            var nodeId = id;
            return new UnassignedEntity(entityID, icon, () => (GraphNode)Activator.CreateInstance(type, nodeId, entityID)!);
        }).OrderBy(e => e.Name).ToList();
    }

    private void AddUnassignedEntity(UnassignedEntity entity)
    {
        if (!GraphEditState.IsEditing)
            GraphEditState.OnEdit();

        var node = entity.Create();
        node.area_id = AreaId;
        GraphEditState.DoAction(new GraphEditAction.AddNode(node));
        UpdateUnassignedEntities();
    }
}
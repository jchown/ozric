    /// Callback for when the diagram removes a node (user hits delete key)
    
    private void OnNodeRemoved(NodeModel nodeModel)
    {
        var node = nodeMappings.GetGraph((GraphNodeModel) nodeModel);
        GetHistory().Do(new GraphEditAction.RemoveNode(node));
        OnHistoryChanged();
        OnSelectionChanged(null);
    }
    */

    public void Dispose()
    {
        Log(LogLevel.Info, "Area {0} unsubscribing from GraphEditState {1}", AreaId, GraphEditState.Id);

        GraphEditState.OnChanged -= OnGraphEditStateChanged;
        GraphEditState.OnDoCommand -= DoCommand;
        GraphEditState.OnDoAction -= DoAction;
        GraphEditState.OnEntityRefresh -= DoEntityRefresh;
        GraphEditState.OnPinChanged -= DoPinChanged;
        GraphEditState.OnAlertChanged -= DoAlertChanged;
        Diagram.SelectionChanged -= OnSelectionChanged;
        Diagram.ContainerChanged -= OnContainerChanged;
        Diagram.Links.Added -= OnDiagramLinkAdded;
        Diagram.Links.Removed -= OnDiagramLinkRemoved;
    }

    private void OnGraphEditStateChanged()
    {
        UpdateUnassignedEntities();
        StateHasChanged();
        UpdateLockedState();
    }

    private void UpdateLockedState()
    {
        SetLocked(GraphEditState.IsLocked());
    }
    
    private void SetLocked(bool locked)
    {
        if (locked)
            Diagram.UnselectAll();

        foreach (var node in Diagram.Nodes)
        {
            node.Locked = locked;

            foreach (var port in node.Ports)
                port.Locked = locked;

            node.RefreshAll();
        }

        foreach (var group in Diagram.Groups)
        {
            group.Locked = locked;

            group.Refresh();
        }

        foreach (var link in Diagram.Links)
        {
            link.Locked = locked;
            link.Refresh();
        }
    }

    private void OnDoUndo()
    {
        GetHistory().UndoLastAction();
        OnHistoryChanged();
    }

    private void OnDoRedo()
    {
        GetHistory().RedoLastAction();
        OnHistoryChanged();
    }

    private void OnDoSetCheckpoint()
    {
        GetHistory().SetCheckpoint();
        OnHistoryChanged();
    }
    
    private void DoAction(GraphEditAction editAction)
    {
        GetHistory().Do(editAction);
        OnHistoryChanged();
    }
    
    private void DoEntityRefresh(string entityID)
    {
        var node = Graph.nodes.Values.FirstOrDefault(n => n is GraphEntity en && en.entityID == entityID);
        if (node == null)
            return;

        var dnode = nodeMappings.GetDiagram(node);
        dnode.Refresh();
    }
    
    private void DoPinChanged(string nodeID, string pinName, Value value)
    {
        var node = Graph.nodes.Get(nodeID);
        if (node == null)
            return;

        node.SetPinValue(pinName, value);
        var dnode = nodeMappings.GetDiagram(node);
        var pinID = $"{node.id}.{pinName}";
        var port = dnode.GetPort(pinID);
        port.RefreshAll();

        // If this is an output pin, update the colors of all connected links
        if (node.HasOutput(pinName))
        {
            var pin = node.GetOutput(pinName);
            foreach (var link in port.Links)
            {
                if (link is OzricLinkModel ozricLink)
                {
                    ozricLink.UpdateColors(pin);
                    ozricLink.Refresh();
                }
            }
        }
    }

    private void DoAlertChanged(string nodeID)
    {
        var node = Graph.nodes.Get(nodeID);
        if (node == null)
            return;

        var dnode = nodeMappings.GetDiagram(node);
        dnode.UpdateAlerts();
    }

    private void PopulateDiagram(string areaId)
    {
        if (_areaId == areaId)
            return;

        _areaId = areaId;

        Log(LogLevel.Info, "Populating diagram from {0}", _areaId);

        var container = Diagram.Container!;

        if (GraphLayout.version < 2)
        {
            GraphLayout.MigrateToNormalized(container.Width, container.Height);
        }

        Diagram.Nodes.Clear();

        nodeMappings.Clear();
        edgeMappings.Clear();

        double minX = 0, minY = 0;
        int x = 0, y = 0, w = 160, h = 120, cols = 6;

        foreach (var node in Graph.nodes.Values.Where(IsActiveInArea))
        {
            var normalized = GraphLayout.GetNodePosition(AreaId, node.id);
            if (normalized == null)
            {
                // Grid fallback: compute pixel position, then normalize for storage
                var gridPixel = new Point(x * w, y * h);
                if (++x == cols)
                {
                    x = 0;
                    ++y;
                }
                normalized = LayoutCoordinateConverter.ToNormalized(gridPixel, container);
                GraphLayout.SetNodePosition(AreaId, node.id, normalized);
            }

            var position = LayoutCoordinateConverter.ToPixels(normalized, container);

            minX = Math.Min(minX, position.X);
            minY = Math.Min(minY, position.Y);

            AddNode(node, position);
        }

        Diagram.SetPan(-(minX - 10), -(minY - 10));

        UpdateUnassignedEntities();

        foreach (var edgeKV in Graph.edges.ToList())
        {
            var edge = edgeKV.Value;

            if (!nodeMappings.HasGraphID(edge.from.nodeID) || !nodeMappings.HasGraphID(edge.to.nodeID))
            {
                // Graph.edges.Remove(edgeKV.Key);
                continue;
            }
            
            var fromD = nodeMappings.GetDiagram(edge.from.nodeID);
            var fromPortID = $"{edge.from.nodeID}.{edge.from.outputName}"; 
            
            var toD = nodeMappings.GetDiagram(edge.to.nodeID);
            var toPortID = $"{edge.to.nodeID}.{edge.to.inputName}";

            var link = new OzricLinkModel(fromD.GetPort(fromPortID), toD.GetPort(toPortID))
            {
                Locked = !GraphEditState.IsEditing
            };

            var sourceNode = Graph.nodes[edge.from.nodeID];
            var sourcePin = sourceNode.GetOutput(edge.from.outputName);
            link.UpdateColors(sourcePin);

            edgeMappings.Add(edge, link);
            Diagram.Links.Add(link);
        }
    }

    private void OnContainerChanged()
    {
        if (Diagram.Container == null)
            return;

        if (_areaId == null)
        {
            // Container just became available - populate the diagram
            if (!string.IsNullOrEmpty(AreaId))
                PopulateDiagram(AreaId);
        }
        else
        {
            // Container resized - reposition all nodes from their normalized coordinates
            RepositionAllNodes();
        }
    }

    private void RepositionAllNodes()
    {
        var container = Diagram.Container;
        if (container == null)
            return;

        foreach (var node in Graph.nodes.Values.Where(IsActiveInArea))
        {
            var normalized = GraphLayout.GetNodePosition(AreaId, node.id);
            if (normalized == null)
                continue;

            if (!nodeMappings.HasGraphID(node.id))
                continue;

            var pixelPos = LayoutCoordinateConverter.ToPixels(normalized, container);
            var nodeModel = nodeMappings.GetDiagram(node);
            nodeModel.SetPosition(pixelPos.X, pixelPos.Y);
        }
    }

    private bool IsActiveInArea(GraphNode graphNode)
    {
        if (graphNode.area_id == AreaId)
            return true;

        if (graphNode.area_id != IHome.GlobalAreaId)
            return false;
        
        var outputs = Graph.GetOutputs(graphNode);

        return outputs.Any(n => n.area_id == AreaId);
    }

    /// Take an existing node in the Graph and add it as the equivalent model object in the Diagram.
    /// The caller is expected to have added it to the DiagramLayout

    public DiagramNode AddNode(GraphNode graphNode, Point position)
    {
        var (x, y) = ConstraintBehavior.ApplyConstraints(Diagram, graphNode, position.X, position.Y);
        
        var diagramNode = CreateModel(graphNode, new Point(x, y));

        nodeMappings.Add(graphNode, diagramNode);
        Diagram.Nodes.Add(diagramNode);

        /*
        var expectedPortCount = node.inputs.Count + node.outputs.Count;
        if (diagramNode.Ports.Count != expectedPortCount)
        {
            throw new Exception($"Graph Node {diagramNode} has {diagramNode.Ports.Count} ports but expected {expectedPortCount}");
        }*/

        int iy = 0, oy = 0, dy = 20;
        
        for (int i = 0; i < diagramNode.Ports.Count; i++)
        {
            var port = diagramNode.Ports[i];
            var iport = (IPort) port;
            port.Position = position.Add(0f, iport.IsInput ? iy : oy);
            if (iport.IsInput)
                iy += dy;
            else
                oy += dy;
        }

        return diagramNode;
    }
    
    /// Remove the model object that represents the given node in the Graph from the Diagram

    public void RemoveNode(GraphNode graphNode)
    {
        var diagramNode = nodeMappings.Remove(graphNode);
        if (Diagram.Nodes.Contains(diagramNode))
            Diagram.Nodes.Remove(diagramNode);
        Graph.RemoveNode(graphNode);
    }

    /// Take an existing edge in the Graph and add it as the equivalent model object in the Diagram.

    public void AddEdge(GraphEdge graphEdge)
    {
        var fromNodeModel = nodeMappings.GetDiagram(graphEdge.from.nodeID);
        var toNodeModel = nodeMappings.GetDiagram(graphEdge.to.nodeID);
        var fromPort = fromNodeModel.GetPort(graphEdge.from.id);
        var toPort = toNodeModel.GetPort(graphEdge.to.id);

        var link = new OzricLinkModel(fromPort, toPort);

        var sourceNode = Graph.nodes[graphEdge.from.nodeID];
        var sourcePin = sourceNode.GetOutput(graphEdge.from.outputName);
        link.UpdateColors(sourcePin);

        edgeMappings.Add(graphEdge, link);
        Diagram.Links.Add(link);
    }
    
    /// Remove the model object that represents the given edge from the Diagram 
    
    public void RemoveEdge(GraphEdge graphEdge)
    {
        var link = edgeMappings.Remove(graphEdge);
        
        if (Diagram.Links.Contains(link))
            Diagram.Links.Remove(link);

        Graph.RemoveEdge(graphEdge);
    }

    private DiagramNode CreateModel(GraphNode graphNode, Point? point = null)
    {
        var model = CreateModelForNode(graphNode, point);
        model.Moving += OnNodeModelMoving;
        model.Locked = !GraphEditState.IsEditing; 
        return model;
    }

    private DiagramNode CreateModelForNode(GraphNode graphNode, Point? point)
    {
        var type = DiagramTypeCatalogue.GetDiagramTypeFor(graphNode);
        var constructor = type.GetConstructors().First(c =>
        {
            var p = c.GetParameters();
            return (p.Length == 2 && p[0].ParameterType == graphNode.GetType() && p[1].ParameterType == typeof(Point));
        });
        return (DiagramNode) constructor.Invoke([graphNode, point]);
    }

    private void OnNodeModelMoving(NodeModel nodeModel)
    {
        GetNodeMove(nodeModel, out var nodeId, out var fromNorm, out var toNorm);
        GetHistory().Node_Moved(nodeModel, nodeId, fromNorm, toNorm);

        OnHistoryChanged();
    }

    private void GetNodeMove(NodeModel nodeModel, out string nodeId, out LayoutPoint fromNorm, out LayoutPoint toNorm)
    {
        nodeId = nodeMappings.GetGraph(nodeModel.Id).id;
        if (nodeId == null)
            throw new Exception("Node not found");

        fromNorm = GraphLayout.GetNodePosition(AreaId, nodeId)!;
        var container = Diagram.Container!;
        toNorm = LayoutCoordinateConverter.ToNormalized(nodeModel.Position, container);
        GraphLayout.SetNodePosition(AreaId, nodeId, toNorm);
    }

    private void OnHistoryChanged()
    {
        GraphEditState.SetHistoryState(GetHistory());
    }

    public List<string> CreateNodes(List<Func<GraphNode>> nodeCreators)
    {
        var container = Diagram.Container!;
        var pos = new Point(20, 20);
        var nodeIDs = new List<string>(nodeCreators.Count);

        foreach (var nodeCreator in nodeCreators)
        {
            var node = nodeCreator();
            Graph.AddNode(node);
            var normalized = LayoutCoordinateConverter.ToNormalized(pos, container);
            GraphLayout.SetNodePosition(AreaId, node.id, normalized);
            AddNode(node, pos);
            pos = pos.Add(20, 0);
            nodeIDs.Add(node.id);
        }

        return nodeIDs;
    }

    private void OnSelectionChanged(SelectableModel? obj)
    {
        var selected = Diagram
            .GetSelectedModels()
            .Select(m => new KeyValuePair<SelectableModel,IGraphObject>(m, GetGraphObject(m)))
            .ToList();
        
        GraphEditState.SetSelected(selected);
    }

    public void Select(params GraphNode[] nodes)
    {
        if (nodes.Length == 0)
        {
            Diagram.UnselectAll();
            return;
        }

        for (int i = 0; i < nodes.Length; i++)
            Diagram.SelectModel(nodeMappings.GetDiagram(nodes[i]), i == 0);
    }

    public Point GetPosition(GraphNode graphNode)
    {
        var normalized = GraphLayout.GetNodePosition(AreaId, graphNode.id)!;
        return LayoutCoordinateConverter.ToPixels(normalized, Diagram.Container!);
    }

    private IGraphObject GetGraphObject(SelectableModel selectableModel)
    {
        if (selectableModel is DiagramNode gnm)
            return nodeMappings.GetGraph(gnm);
                
        if (selectableModel is LinkModel lm)
            return edgeMappings.GetGraph(lm);
                
        throw new InvalidOperationException();
    }

    public void RenameNode(string originalID, string newID)
    {
        var changedEdges = Graph.edges.Values.Where(e => e.from.nodeID == originalID || e.to.nodeID == originalID).ToList();
        foreach (var changedEdge in changedEdges)
        {
            var edge = changedEdge.Reroute(originalID, newID);
            Graph.edges.Remove(changedEdge.id);
            Graph.edges.Add(edge.id, edge);
        }
        
        //  We keep graph nodes keyed by ID in three places:
        
        //  1. The graph
        //  2. The map between graph nodes and diagram nodes
        //  3. The stored data of diagram nodes (currently just positions)

        var node = Graph.nodes[originalID];
        nodeMappings.Remap(node, newID);
        node.id = newID;
        Graph.nodes.Remove(originalID);
        Graph.nodes[newID] = node;

        GraphLayout.RemapNodeID(originalID, newID);

        Reload(node);
    }

    /// Tell a Diagram model object to update itself and load its state from the Graph model.
    
    public void Reload(GraphNode graphNode)
    {
        var nodeModel = nodeMappings.GetDiagram(graphNode.id);
        nodeModel.Load();
        nodeModel.Refresh();
    }

    ///  Callback from the Diagram
    
    private void OnDiagramLinkAdded(BaseLinkModel link)
    {
        if (link.Target.Model is null)
        {
            //  An empty link being dragged (listen for its connection)

            link.SourceChanged += OnDiagramLinkSourceChanged;
            link.TargetAttached += OnDiagramLinkAttached;
            link.TargetChanged += OnDiagramLinkTargetChanged;
        }

    //else
    //In case it was connected instantaneously (via code)
       //     RegisterUndoHistoryAction(new GraphAction.AddLink(link));
    }

    private void UnsubscribeLinkDragHandlers(BaseLinkModel link)
    {
        link.SourceChanged -= OnDiagramLinkSourceChanged;
        link.TargetAttached -= OnDiagramLinkAttached;
        link.TargetChanged -= OnDiagramLinkTargetChanged;
    }

    private void OnDiagramLinkRemoved(BaseLinkModel link)
    {
        //  Covers the abandoned-drag case: user started dragging a link but
        //  released over empty space, so the library removes it without ever
        //  attaching a target.
        UnsubscribeLinkDragHandlers(link);
    }

    private void OnDiagramLinkTargetChanged(BaseLinkModel link, Anchor anchorFrom, Anchor anchorTo)
    {
        UnsubscribeLinkDragHandlers(link);

        var fromPort = (PinPort) link.Source.Model!;
        var toPort = (PinPort) link.Target.Model!;

        var fromNodeModel = (DiagramNode) fromPort.Parent;
        var toNodeModel = (DiagramNode) toPort.Parent;
        
        var createPin = link.Target.Model is PortInputAdd;

        var fromNode = nodeMappings.GetGraph(fromNodeModel);
        var toNode = nodeMappings.GetGraph(toNodeModel);

        var fromPin = fromNodeModel.GetPin(fromPort);

        if (!createPin)
        {
            var toPin = toNodeModel.GetPin(toPort);
            
            // Check the user hasn't just duplicated an existing link

            var from = new OutputSelector(fromNode.id, fromPin.name);
            var to = new InputSelector(toNode.id, toPin.name);
            var edge = new GraphEdge(from, to);

            if (Graph.edges.ContainsKey(edge.id))
                return;

            //  The diagram link has been added by the library, but we need to remove it and then add it 
            //  back to both the diagram and the model in order for the undo/redo logic to be simple.

            Diagram.Links.Remove(link);

            DoAction(new GraphEditAction.AddEdge(edge));
        }
        else
        {
            //  We'll need to create a pin/port as well as the edge/link 
            
            Diagram.Links.Remove(link);

            var toVarInput = toNode as GraphVariableInputs ?? throw new Exception("Expect variable inputs");
            var newPinName = toVarInput.NextPinName();
            
            var from = new OutputSelector(fromNode.id, fromPin.name);
            var to = new InputSelector(toNode.id, newPinName);
            var edge = new GraphEdge(from, to);

            var addPort = new GraphEditAction.AddInput(toVarInput, newPinName);
            var addEdge = new GraphEditAction.AddEdge(edge);

            DoAction(new GraphEditAction.EditActions(new List<GraphEditAction>{ addPort, addEdge }));
        }
    }

    private void OnDiagramLinkSourceChanged(BaseLinkModel arg1, Anchor arg2, Anchor arg3)
    {
        
    }

    private void OnDiagramLinkAttached(BaseLinkModel link)
    {
        UnsubscribeLinkDragHandlers(link);
    }


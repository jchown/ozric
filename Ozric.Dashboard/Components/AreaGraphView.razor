@using Blazor.Diagrams
@using Ozric.Dashboard.Model
@using Blazor.Diagrams.Components
@using Blazor.Diagrams.Core.Models.Base
@using Blazor.Diagrams.Options
@using Ozric.Dashboard.Diagram
@using Ozric.Engine.Extensions
@using Ozric.Engine.Graph
@using Ozric.Engine.Graph.Entities
@using Ozric.Engine
@using LogLevel = Ozric.Engine.Utils.LogLevel
@using Ozric.Engine.Values
@using Ozric.Service
@using Anchor = Blazor.Diagrams.Core.Anchors.Anchor
@inherits DashboardComponent
@implements IDisposable

@if (Diagram != null)
{
    <div class="diagram-container @(IsRunning ? "running" : "") @(GraphEditState.IsEditing ? "editable" : "")">
        @if (_unassignedEntities.Count > 0 && GraphEditState.IsEditing)
        {
            <div class="unassigned-bubble @(_unassignedExpanded ? "expanded" : "")" @onclick="ToggleUnassigned" @onclick:stopPropagation="true">
                @if (!_unassignedExpanded)
                {
                    <span class="unassigned-count">@_unassignedEntities.Count</span>
                    <span class="unassigned-label">unassigned</span>
                }
                else
                {
                    <div class="unassigned-header">
                        <span>@_unassignedEntities.Count unassigned</span>
                    </div>
                    <div class="unassigned-list">
                        @foreach (var entity in _unassignedEntities)
                        {
                            var e = entity;
                            <div class="unassigned-item">
                                <span class="iconify" data-icon="@e.Icon"></span>
                                <span class="unassigned-name">@e.Name</span>
                                <button class="unassigned-add" @onclick="() => AddUnassignedEntity(e)" @onclick:stopPropagation="true" title="Add node">
                                    <span class="iconify" data-icon="mdi:plus-circle-outline"></span>
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>
        }
        <CascadingValue Value="Diagram">
            <DiagramCanvas></DiagramCanvas>
        </CascadingValue>
    </div>
}

@code {

    [Parameter]
    public string AreaId { get; set; }

    [Parameter]
    public Graph Graph { get; set; }

    [Parameter]
    public GraphLayout GraphLayout { get; set; }

    [Parameter]
    public GraphEditState GraphEditState { get; set; }

    [CascadingParameter]
    public IOzricService OzricService { get; set; }

    public BlazorDiagram Diagram { get; set; }

    private bool IsRunning => !OzricService.Status.paused && !GraphEditState.IsEditing;
    private bool IsChanged => !IsNotChanged;
    private bool IsNotChanged => GetHistory().IsAtCheckpoint();
    private bool CanUndo => GraphEditState.IsEditing && GetHistory().CanUndo();
    private bool CanRedo => GraphEditState.IsEditing && GetHistory().CanRedo();

    private EditHistory? _history;
    private EditHistory GetHistory() => _history!;

    private readonly Mapping<GraphNode, DiagramNode> nodeMappings = new();
    private readonly Mapping<GraphEdge, LinkModel> edgeMappings = new();
    
    private string _areaId;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        
        Log(LogLevel.Info, "Area {0} subscribing to GraphEditState {1}", AreaId, GraphEditState.Id);
        
        GraphEditState.OnChanged += OnGraphEditStateChanged;
        GraphEditState.OnDoCommand += DoCommand;
        GraphEditState.OnDoAction += DoAction;
        GraphEditState.OnEntityRefresh += DoEntityRefresh;
        GraphEditState.OnPinChanged += DoPinChanged;
        GraphEditState.OnAlertChanged += DoAlertChanged;
        
        var options = new BlazorDiagramOptions
        {
//            DeleteKey = "Delete", // What key deletes te selected nodes/links
/* 9.0
            DeleteKey = "",
            DefaultNodeComponent = null, // Default component for nodes
            */


            Links =
            {
                EnableSnapping = true,
                SnappingRadius = 20
            },
            AllowMultiSelection = true, // Whether to allow multi selection using CTRL
        };
        options.AllowPanning = false;
        options.Zoom.Enabled = false;
        
        Diagram = new BlazorDiagram(options);
        
        foreach (var modelType in DiagramTypeCatalogue.GetDiagramTypes())
            Diagram.RegisterComponent(modelType, typeof(GraphNodeComponent));

        Diagram.RegisterComponent<OzricLinkModel, OzricLinkWidget>();

        Diagram.SelectionChanged += OnSelectionChanged;
        Diagram.ContainerChanged += OnContainerChanged;
        Diagram.Links.Added += OnDiagramLinkAdded;
        Diagram.Links.Removed += OnDiagramLinkRemoved;

        /* 9.0
        diagram.KeyDown += GraphEditState.KeyDown;
        */

        _history = new EditHistory(this);
        UpdateLockedState();

        //Diagram.AddConstraintBehaviour();
        //Diagram.AddLinkDragBehavior();
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (string.IsNullOrEmpty(AreaId))
            return;

        if (Diagram == null)
            throw new InvalidOperationException("Diagram is not initialized");

        if (_areaId == AreaId)
            return;

        Log(LogLevel.Debug, "Area {0} parametersSet", AreaId);

        if (Diagram.Container != null)
        {
            PopulateDiagram(AreaId);
        }
        // else: OnContainerChanged will call PopulateDiagram when the container becomes available
    }

    private void DoCommand(GraphEditState.Command command)
    {
        switch (command)
        {
            case GraphEditState.Command.Undo:
                GetHistory().UndoLastAction();
                OnHistoryChanged();
                break;
                
            case GraphEditState.Command.Redo:
                GetHistory().RedoLastAction();
                OnHistoryChanged();
                break;
                
            case GraphEditState.Command.SetCheckpoint:
                GetHistory().SetCheckpoint();
                OnHistoryChanged();
                break;
                
            case GraphEditState.Command.Delete:
                DoDelete();
                break;
                
            case GraphEditState.Command.Rebuild:
                PopulateDiagram(AreaId);
                break;
                
            default:
                throw new ArgumentOutOfRangeException(nameof(command), command, null);
        }
    }


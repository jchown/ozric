@using Ozric.Engine.Values
@using Ozric.Dashboard.Model
<MudDialog>
    <DialogContent>

        <MudContainer Style="max-height: 60vh; overflow-y: scroll;">

            <MudTextField Label="Title" HelperText="The unique name for this node" @bind-Value="ID" For="@(() => ID)" Immediate="true"/>

            <MudDivid1er DividerType="DividerType.Middle" Class="my-4"/>

            @if (modeValues.Count > 0)
            {
                <MudTable Items="@modeValues" T="Engine.Graph.Logic.GraphModeSwitch.ModeValues"
                          @bind-SelectedItem="selected"
                          CanCancelEdit="true"
                          CommitEditTooltip="Apply"
                          CancelEditTooltip="Revert"
                          RowEditPreview="BackupItem"
                          RowEditCancel="ResetItem"
                          ApplyButtonPosition="TableApplyButtonPosition.End"
                          Dense="true" Class="border-none" Elevation="0">
                    <ColGroup>
                        <col style="width:150px;"/>
                        <col/>
                        <col style="width:150px;"/>
                    </ColGroup>
                    <HeaderContent>
                        <MudTh>Mode</MudTh>
                        @foreach (var key in Node.GetKeys())
                        {
                            <MudTh>@key</MudTh>
                        }
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Mode">@context.mode</MudTd>
                        @foreach (var key in Node.GetKeys())
                        {
                            <MudTd DataLabel="@key">
                                <ValueComponent Value="context.values[key]"/>
                            </MudTd>
                        }
                    </RowTemplate>
                    <RowEditingTemplate>
                        <MudTd DataLabel="Mode">
                            <ValueEditorComponent Value="@context.mode" OnEdited="v => context.mode = (Mode) v"/>
                        </MudTd>
                        @foreach (var key in Node.GetKeys())
                        {
                            <MudTd DataLabel="@key">
                                <ValueEditorComponent Value="context.values[key]" OnEdited="v => context.values[key] = v"/>
                            </MudTd>
                        }
                    </RowEditingTemplate>

                </MudTable>

                <MudDivider DividerType="DividerType.Middle" Class="my-2"/>
            }

            <MudGrid>
                <MudItem xs="9">
                    <MudTextField Label="Add Mode" HelperText="The mode" @bind-Value="addMode"/>
                </MudItem>
                <MudItem xs="3" Class="align-self-center">
                    <MudButton OnClick="Add">Add</MudButton>
                </MudItem>
            </MudGrid>

        </MudContainer>

    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Save" Disabled="!HasChanges">Save</MudButton>
        <MudButton OnClick="Cancel">Close</MudButton>
    </DialogActions>

</MudDialog>

@code {

    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public DiagramModeSwitch Model { get; set; }

    [Parameter]
    public Engine.Graph.Logic.GraphModeSwitch Node { get; set; }

    private string ID;
    private Engine.Graph.Logic.GraphModeSwitch.ModeValues selected;
    private List<Engine.Graph.Logic.GraphModeSwitch.ModeValues> modeValues = new();
    private Engine.Graph.Logic.GraphModeSwitch.ModeValues preEdit;
    private string addMode { get; set; } = "";

    void Cancel() => MudDialog.Cancel();
    void Save() => MudDialog.Close(DialogResult.Ok(GetChanges()));

    private bool HasChanges => GetChanges().Count > 0;

    protected override void OnInitialized()
    {
        ID = Node.id;
        modeValues = new List<Engine.Graph.Logic.GraphModeSwitch.ModeValues>(Node.modeValues.Select(mv => mv.Clone()));
    }

    private List<GraphEditAction> GetChanges()
    {
        var changes = new List<GraphEditAction>();
        if (ID != Node.id)
            changes.Add(new GraphEditAction.RenameNode(Node, ID));

        if (!modeValues.SequenceEqual(Node.modeValues))
            changes.Add(new GraphEditAction.EditNode(Node, Node.GetProperty(nameof(Node.modeValues)), modeValues));

        return changes;
    }

    private void Add()
    {
        modeValues.Add(new Engine.Graph.Logic.GraphModeSwitch.ModeValues(new Mode(addMode), modeValues.Last().values.Clone()));
        addMode = "";
    }

    private void BackupItem(object element)
    {
        preEdit = new Engine.Graph.Logic.GraphModeSwitch.ModeValues(((Engine.Graph.Logic.GraphModeSwitch.ModeValues)element).mode, ((Engine.Graph.Logic.GraphModeSwitch.ModeValues)element).values);
    }

    private void ResetItem(object element)
    {
        var pattern = (Engine.Graph.Logic.GraphModeSwitch.ModeValues)element;
        pattern.mode = preEdit.mode;
        pattern.values = preEdit.values;
    }

}

}
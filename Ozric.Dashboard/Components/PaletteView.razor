@using Ozric.Engine.Graph
@using OzricEngine.Nodes
@using OzricEngine.Values
@using OzricService
@using ValueType = Ozric.Engine.Values.ValueType
@inject IOzricService OzricService
@inject IDialogService DialogService

<MudContainer Style="height: 100%; overflow-y: scroll">
    <MudText Typo="Typo.h6">Colors</MudText>
    
    <MudGrid>
        @foreach (var area in _currentColors)
        {
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudCard>
                    <MudCardMedia Style="@GetMediaStyle(area)" Height="120" />
                    <MudCardContent>
                        <MudText Typo="Typo.h6">@area.Key</MudText>
                        <MudText Typo="Typo.subtitle1">Used by @NumNodesUsing(area.Key) nodes.</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => OnClickedView(area.Key))">View</MudButton>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" Disabled="@(GraphEditState.IsLocked())">Delete</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
    
</MudContainer>

@code {
    [Parameter]
    public GraphEditState GraphEditState { get; set; }
    
    [Parameter]
    public Graph Graph { get; set; }
    
    private Dictionary<string, ColorValue> _currentColors;
    private Dictionary<string, ColorValue> _editedColors;
    private bool _liveEdit;

    private bool HasChanges => GetChanges().Count > 0;
    private string CancelButtonText => HasChanges ? "Cancel" : "Close";

    protected override void OnInitialized()
    {
        _currentColors = OzricService.Graph.nodes
            .Where(n => n.Value is GraphConstant c && c.ConstantType == ValueType.Color)
            .ToDictionary(n => n.Key, n => (ColorValue) ((GraphConstant) n.Value).ConstantValue!);

        _editedColors = new Dictionary<string, ColorValue>(_currentColors);
    }
    
    private List<Action<Settings>> GetChanges()
    {
        var changes = new List<Action<Settings>>();

        return changes;
    }

    private int NumNodesUsing(string areaKey)
    {
        return 1; // Placeholder for actual logic to count nodes using the color
    }

    private string GetMediaStyle(KeyValuePair<string, ColorValue> area)
    {
        if (area.Value.brightness == 0)
            return "background: linear-gradient(135deg, #333 0%, #000 50%, #333 100%)";
        
        return $"background-color: #{area.Value.ToHexString()}";
    }

    private async Task OnClickedView(string id)
    {
        var parameters = new DialogParameters
        {
            { "Model", null },
            { "Node", Graph.nodes[id] }
        };

        var options = Dialogs.StandardOptions();

        var dialog = await DialogService.ShowAsync<ConstantColorDialog>(id, parameters, options);
        var result = await dialog.Result;
        var changes = result?.Data as List<GraphEditAction>;
        if (changes == null || changes.Count == 0)
            return;

        if (GraphEditState.Mode == GraphEditState.EditMode.View)
            GraphEditState.OnEdit();

        GraphEditState.DoAction(new GraphEditAction.EditActions(changes));
        StateHasChanged();
    }
}